{
  "name": "dragodinde-notif",
  "version": "0.2.0",
  "description": "Dragodinde breeding tracker (Effect + SQLite) with Discord notifications when watched stats hit 20k",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "web"
  ],
  "scripts": {
    "core:build": "npm -w @dd/core run build",
    "start": "npm run core:build && tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "dev": "npm run core:build && tsx watch src/main.ts",
    "web:dev": "npm -w dragodinde-web run dev",
    "web:build": "npm run core:build && npm -w dragodinde-web run build",
    "build": "npm run core:build && npm -w dragodinde-web run build",
    "build:server": "npm run core:build && tsc -p tsconfig.build.json",
    "typecheck": "npm run core:build && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@dd/core": "*",
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@effect/sql": "0.51.1",
    "@effect/sql-sqlite-node": "0.52.0",
    "ai": "^6.0.207",
    "better-auth": "^1.6.19",
    "better-sqlite3": "12.10.0",
    "dotenv": "^16.6.1",
    "effect": "3.21.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@effect/vitest": "0.29.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "3.2.6"
  }
}
