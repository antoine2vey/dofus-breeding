{
  "name": "dragodinde-notif",
  "version": "0.2.0",
  "description": "Dragodinde breeding tracker (Effect + SQLite) with Discord notifications when watched stats hit 20k",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "build": "npm --prefix web install && npm --prefix web run build",
    "build:server": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@effect/sql": "0.51.1",
    "@effect/sql-sqlite-node": "0.52.0",
    "better-sqlite3": "12.10.0",
    "effect": "3.21.3"
  },
  "devDependencies": {
    "@effect/vitest": "0.29.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "3.2.6"
  }
}
