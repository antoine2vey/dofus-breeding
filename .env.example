# Optional — you can also set the webhook from the ⚙︎ Discord button in the UI.
DISCORD_WEBHOOK_URL=

# ── docker compose ──────────────────────────────────────────────
# Host port mapped to the container's fixed internal port 3000.
HOST_PORT=3000
# Speed up the tick for testing (default 10000 = 10s like the game).
# TICK_MS=1000
# Under docker compose, DATABASE_FILE is fixed to /data/data.db (the
# dragodinde-data volume) and the PORT/DATABASE_FILE below are IGNORED.

# ── bare-metal (npm start) only ─────────────────────────────────
PORT=3000
DATABASE_FILE=data.db

# ── Auth (Better Auth + Discord OAuth) ──────────────────────────
# Register a Discord application (https://discord.com/developers/applications),
# add an OAuth2 redirect URI of  <BETTER_AUTH_URL>/api/auth/callback/discord ,
# then fill these in. Without them the app still boots but sign-in is disabled.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Public base URL of this server (no trailing slash). Dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Random 32+ char secret for signing sessions:  openssl rand -base64 32
BETTER_AUTH_SECRET=
# Your numeric Discord user id — the seed migration (#3) assigns existing data to you.
SEED_OWNER_DISCORD_ID=
# After setting the above, create Better Auth's tables once:  npx @better-auth/cli migrate -y
