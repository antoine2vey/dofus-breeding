# Optional — you can also set the webhook from the ⚙︎ Discord button in the UI.
DISCORD_WEBHOOK_URL=

# ── docker compose ──────────────────────────────────────────────
# Host port mapped to the container's fixed internal port 3000.
HOST_PORT=3000
# Speed up the tick for testing (default 10000 = 10s like the game).
# TICK_MS=1000
# Under docker compose, DATABASE_FILE is fixed to /data/data.db (the
# dragodinde-data volume) and the PORT/DATABASE_FILE below are IGNORED.

# ── bare-metal (npm start) only ─────────────────────────────────
PORT=3000
DATABASE_FILE=data.db
